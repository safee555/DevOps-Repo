        <mxCell id="3C85waHqrZ4sNqxIHi9B-38" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;h2 data-section-id=&quot;1pi2wio&quot; data-start=&quot;474&quot; data-end=&quot;499&quot;&gt;&lt;strong data-start=&quot;477&quot; data-end=&quot;499&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 12px;&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;1. End User Access&lt;/font&gt;&lt;/strong&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;501&quot; data-end=&quot;647&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;cq92kc&quot; data-start=&quot;501&quot; data-end=&quot;569&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;The &lt;strong data-start=&quot;507&quot; data-end=&quot;519&quot;&gt;End User&lt;/strong&gt; accesses the application over the &lt;strong data-start=&quot;554&quot; data-end=&quot;566&quot;&gt;Internet&lt;/strong&gt;.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1pdggmc&quot; data-start=&quot;570&quot; data-end=&quot;647&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Direct access to backend resources is &lt;strong data-start=&quot;610&quot; data-end=&quot;625&quot;&gt;not allowed&lt;/strong&gt; for security reasons.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;649&quot; data-end=&quot;652&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;c8mqkh&quot; data-start=&quot;654&quot; data-end=&quot;706&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;657&quot; data-end=&quot;706&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;2. Entry Through Azure Firewall (Hub Network)&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;708&quot; data-end=&quot;1029&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1gd2a6z&quot; data-start=&quot;708&quot; data-end=&quot;788&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;All incoming traffic first reaches the &lt;strong data-start=&quot;749&quot; data-end=&quot;767&quot;&gt;Azure Firewall&lt;/strong&gt; in the &lt;strong data-start=&quot;775&quot; data-end=&quot;787&quot;&gt;Hub VNet&lt;/strong&gt;.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;r865gg&quot; data-start=&quot;789&quot; data-end=&quot;955&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;The firewall acts as a &lt;strong data-start=&quot;814&quot; data-end=&quot;848&quot;&gt;central security control point&lt;/strong&gt;:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;852&quot; data-end=&quot;955&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;218lva&quot; data-start=&quot;852&quot; data-end=&quot;869&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Filters traffic&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;17vjyyl&quot; data-start=&quot;872&quot; data-end=&quot;910&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Allows only approved ports/protocols&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1ke1815&quot; data-start=&quot;913&quot; data-end=&quot;955&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Blocks unauthorized/malicious requests&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;82ukqu&quot; data-start=&quot;957&quot; data-end=&quot;1029&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Traffic is then routed internally using the firewall’s &lt;strong data-start=&quot;1014&quot; data-end=&quot;1028&quot;&gt;private IP&lt;/strong&gt;.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;1031&quot; data-end=&quot;1034&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;1597ly8&quot; data-start=&quot;1036&quot; data-end=&quot;1083&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;1039&quot; data-end=&quot;1083&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;3. New Resource Group &amp;amp; VNet Integration&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;1085&quot; data-end=&quot;1344&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;xa7vv0&quot; data-start=&quot;1085&quot; data-end=&quot;1134&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;A &lt;strong data-start=&quot;1089&quot; data-end=&quot;1116&quot;&gt;new Resource Group (RG)&lt;/strong&gt; has been created.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;4u53zz&quot; data-start=&quot;1135&quot; data-end=&quot;1198&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Inside this RG, a &lt;strong data-start=&quot;1155&quot; data-end=&quot;1185&quot;&gt;new Virtual Network (VNet)&lt;/strong&gt; is deployed.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;10afnlo&quot; data-start=&quot;1199&quot; data-end=&quot;1344&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;This new VNet is &lt;strong data-start=&quot;1218&quot; data-end=&quot;1246&quot;&gt;peered with the Hub VNet&lt;/strong&gt;, enabling:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1260&quot; data-end=&quot;1344&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1jsvkxq&quot; data-start=&quot;1260&quot; data-end=&quot;1290&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Secure communication via Hub&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;dkkem7&quot; data-start=&quot;1293&quot; data-end=&quot;1344&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Centralized traffic inspection through Firewall&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;1346&quot; data-end=&quot;1349&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;1rp882k&quot; data-start=&quot;1351&quot; data-end=&quot;1398&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;1354&quot; data-end=&quot;1398&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;4. Hub-Spoke Architecture with Isolation&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;p data-start=&quot;1400&quot; data-end=&quot;1456&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;The environment follows an enhanced &lt;strong data-start=&quot;1436&quot; data-end=&quot;1455&quot;&gt;Hub-Spoke model&lt;/strong&gt;:&lt;/font&gt;&lt;/p&gt;&lt;/h2&gt;&lt;h3 data-section-id=&quot;q7sxw0&quot; data-start=&quot;1458&quot; data-end=&quot;1474&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;1462&quot; data-end=&quot;1474&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;Hub VNet&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;1475&quot; data-end=&quot;1590&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;16oxf2u&quot; data-start=&quot;1475&quot; data-end=&quot;1521&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Contains:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1489&quot; data-end=&quot;1521&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;19ydepr&quot; data-start=&quot;1489&quot; data-end=&quot;1505&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Azure Firewall&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;lfi6ew&quot; data-start=&quot;1508&quot; data-end=&quot;1521&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;VPN Gateway&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;19wneot&quot; data-start=&quot;1522&quot; data-end=&quot;1590&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Acts as:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1535&quot; data-end=&quot;1590&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;109rbkk&quot; data-start=&quot;1535&quot; data-end=&quot;1558&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Central routing layer&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;t1f2fg&quot; data-start=&quot;1561&quot; data-end=&quot;1590&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Security inspection point&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;/h2&gt;&lt;h3 data-section-id=&quot;1g9f8nu&quot; data-start=&quot;1592&quot; data-end=&quot;1631&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;1596&quot; data-end=&quot;1631&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;Spoke VNets (Spoke 1 &amp;amp; Spoke 2)&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h3&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;1632&quot; data-end=&quot;1872&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1pdqir7&quot; data-start=&quot;1632&quot; data-end=&quot;1684&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Each spoke contains its own application resources.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1kod129&quot; data-start=&quot;1685&quot; data-end=&quot;1872&quot;&gt;&lt;br&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;strong data-start=&quot;1687&quot; data-end=&quot;1708&quot;&gt;Important Change:&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;1711&quot; data-end=&quot;1872&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;e5u9j4&quot; data-start=&quot;1711&quot; data-end=&quot;1770&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;❌ &lt;strong data-start=&quot;1715&quot; data-end=&quot;1770&quot;&gt;Spoke 1 and Spoke 2 are NOT connected to each other&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;uk7vrl&quot; data-start=&quot;1773&quot; data-end=&quot;1809&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;❌ No direct peering between spokes&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;13unvu5&quot; data-start=&quot;1812&quot; data-end=&quot;1872&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;✅ Communication only via &lt;strong data-start=&quot;1839&quot; data-end=&quot;1870&quot;&gt;Hub (if explicitly allowed)&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;p data-start=&quot;1874&quot; data-end=&quot;1988&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;👉 This ensures &lt;strong data-start=&quot;1890&quot; data-end=&quot;1933&quot;&gt;complete isolation between environments&lt;/strong&gt; (e.g., prod vs non-prod, or different business units).&lt;/font&gt;&lt;/p&gt;&lt;hr data-start=&quot;1990&quot; data-end=&quot;1993&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;13dtyvg&quot; data-start=&quot;1995&quot; data-end=&quot;2034&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;1998&quot; data-end=&quot;2034&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;5. VPN Access for Internal Users&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;2036&quot; data-end=&quot;2178&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1rz9y1t&quot; data-start=&quot;2036&quot; data-end=&quot;2099&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Internal users/admins connect via &lt;strong data-start=&quot;2072&quot; data-end=&quot;2098&quot;&gt;VPN Gateway in the Hub&lt;/strong&gt;.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1e6uuo3&quot; data-start=&quot;2100&quot; data-end=&quot;2178&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Provides:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;2114&quot; data-end=&quot;2178&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;zc9s0a&quot; data-start=&quot;2114&quot; data-end=&quot;2132&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Encrypted access&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;mzqlob&quot; data-start=&quot;2135&quot; data-end=&quot;2178&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;No public exposure of internal services&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;2180&quot; data-end=&quot;2183&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;11l0yre&quot; data-start=&quot;2185&quot; data-end=&quot;2229&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;2188&quot; data-end=&quot;2229&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;6. Application Layer (Backend Subnet)&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;2231&quot; data-end=&quot;2481&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;zos2rg&quot; data-start=&quot;2231&quot; data-end=&quot;2328&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;After firewall validation, traffic is routed to the &lt;strong data-start=&quot;2285&quot; data-end=&quot;2303&quot;&gt;Backend Subnet&lt;/strong&gt; in the respective spoke.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;d349fz&quot; data-start=&quot;2329&quot; data-end=&quot;2400&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Hosts &lt;strong data-start=&quot;2337&quot; data-end=&quot;2367&quot;&gt;Web Server (AZWUKSWEBDC01)&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;2372&quot; data-end=&quot;2400&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1bcvnh4&quot; data-start=&quot;2372&quot; data-end=&quot;2400&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Private IP: &lt;code data-start=&quot;2386&quot; data-end=&quot;2400&quot;&gt;192.168.1.37&lt;/code&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;17qqbse&quot; data-start=&quot;2401&quot; data-end=&quot;2481&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Responsible for:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;2422&quot; data-end=&quot;2481&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;7nncy8&quot; data-start=&quot;2422&quot; data-end=&quot;2448&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Processing user requests&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;x5qmmr&quot; data-start=&quot;2451&quot; data-end=&quot;2481&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Handling application logic&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;2483&quot; data-end=&quot;2486&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;149zfxs&quot; data-start=&quot;2488&quot; data-end=&quot;2526&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;2491&quot; data-end=&quot;2526&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;7. Data Layer (Database Subnet)&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;2528&quot; data-end=&quot;2694&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;fsgucc&quot; data-start=&quot;2528&quot; data-end=&quot;2595&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Web server communicates with &lt;strong data-start=&quot;2559&quot; data-end=&quot;2573&quot;&gt;SQL Server&lt;/strong&gt; in a separate subnet.&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;19tnwz4&quot; data-start=&quot;2596&quot; data-end=&quot;2627&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;SQL Server IP: &lt;code data-start=&quot;2613&quot; data-end=&quot;2627&quot;&gt;10.193.101.4&lt;/code&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1i16vol&quot; data-start=&quot;2628&quot; data-end=&quot;2694&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Benefits:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;2642&quot; data-end=&quot;2694&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1okcpxb&quot; data-start=&quot;2642&quot; data-end=&quot;2660&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Strong isolation&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1erq7gs&quot; data-start=&quot;2663&quot; data-end=&quot;2694&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;No direct internet exposure&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;2696&quot; data-end=&quot;2699&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;1xy2vku&quot; data-start=&quot;2701&quot; data-end=&quot;2744&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;2704&quot; data-end=&quot;2744&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;8. Controlled Internal Communication&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ul data-start=&quot;2746&quot; data-end=&quot;2959&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;ath6az&quot; data-start=&quot;2746&quot; data-end=&quot;2797&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Communication flow:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;2770&quot; data-end=&quot;2797&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;1p19dms&quot; data-start=&quot;2770&quot; data-end=&quot;2797&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Web Server → SQL Server&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1d3vrxy&quot; data-start=&quot;2798&quot; data-end=&quot;2851&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Happens entirely over &lt;strong data-start=&quot;2822&quot; data-end=&quot;2851&quot;&gt;private IPs داخل the VNet&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;gne74s&quot; data-start=&quot;2852&quot; data-end=&quot;2959&quot;&gt;&lt;br&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;strong data-start=&quot;2854&quot; data-end=&quot;2891&quot;&gt;Spoke-to-Spoke traffic is blocked&lt;/strong&gt;, ensuring:&lt;br&gt;&lt;/font&gt;&lt;ul data-start=&quot;2905&quot; data-end=&quot;2959&quot;&gt;&lt;br&gt;&lt;li data-section-id=&quot;2qhsnd&quot; data-start=&quot;2905&quot; data-end=&quot;2926&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;No lateral movement&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;ir8xio&quot; data-start=&quot;2929&quot; data-end=&quot;2959&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Better security boundaries&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;br&gt;&lt;/li&gt;&lt;br&gt;&lt;/ul&gt;&lt;hr data-start=&quot;2961&quot; data-end=&quot;2964&quot;&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;xfj2aq&quot; data-start=&quot;2966&quot; data-end=&quot;3002&quot;&gt;&lt;span role=&quot;text&quot;&gt;&lt;strong data-start=&quot;2969&quot; data-end=&quot;3002&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;9. Response Flow Back to User&lt;/font&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;&lt;h2 data-section-id=&quot;vquq7l&quot; data-start=&quot;146&quot; data-end=&quot;178&quot;&gt;&lt;ol data-start=&quot;3004&quot; data-end=&quot;3197&quot;&gt;&lt;li data-section-id=&quot;6eu30z&quot; data-start=&quot;3004&quot; data-end=&quot;3048&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;SQL Server sends response to Web Server&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1ocgzt9&quot; data-start=&quot;3049&quot; data-end=&quot;3086&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Web Server prepares final output&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1dndm9h&quot; data-start=&quot;3087&quot; data-end=&quot;3141&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Traffic is routed back through &lt;strong data-start=&quot;3121&quot; data-end=&quot;3139&quot;&gt;Azure Firewall&lt;/strong&gt;&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;br&gt;&lt;li data-section-id=&quot;1bd4nfh&quot; data-start=&quot;3142&quot; data-end=&quot;3197&quot;&gt;&lt;font style=&quot;font-size: 32px;&quot;&gt;&lt;br&gt;Firewall sends response to &lt;strong data-start=&quot;3172&quot; data-end=&quot;3197&quot; style=&quot;&quot;&gt;End User via Internet&lt;/strong&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/h2&gt;" vertex="1">
